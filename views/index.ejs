<%- include('partials/head') %>
<%- include('partials/nav') %>

    <section class="hero">
        <div class="hero-wrapper">
            <div class="hero-content" style="text-align: center; width: 100%;">
                <h1>Mohamed Aziz Haddadi</h1>
                <h2>DFIR Specialist | Blue Team Analyst | Pulgaa</h2>
                <p>Specialized in Digital Forensics, Incident Response, and Blue Team operations. Expert in malware analysis, threat intelligence, and SOC analysis with proven CTF achievements.</p>
                <a href="#contact" class="cta-button">Get In Touch</a>
            </div>
        </div>
    </section>

    <section id="about">
        <h2>About Me</h2>
        <div style="text-align: center; max-width: 800px; margin: 0 auto;">
            <p style="font-size: 1.1rem; line-height: 1.8; color: #b8b8d1;">
                I'm a cybersecurity professional specializing in Digital Forensics & Incident Response (DFIR) and Blue Team operations. 
                My expertise includes malware analysis, threat intelligence, and SOC analysis. Ranked in the top 1% on TryHackMe, 
                I've consistently achieved top placements in competitive CTFs including Top 4 in Securinets Qualifications, 
                Top 10 in Cybertek, Top 5 in Darkest Hour 2026, and notable achievements in Tio CTF. Currently seeking opportunities in cybersecurity roles and internships 
                where I can apply my defensive security skills to protect organizations from evolving threats.
            </p>
        </div>
    </section>

    <section id="achievements">
        <h2>Achievements & Roles</h2>
        <div class="ctf-list">
            <div class="ctf-item">
                <h3>Technical Team Member</h3>
                <p class="rank">🛡️ Securinets</p>
                <p style="color: #b8b8d1; margin-top: 0.5rem;">Active member of the Securinets Technical Team, contributing to cybersecurity initiatives, CTF organizations, and technical workshops.</p>
            </div>
            <div class="ctf-item">
                <h3>CTF Player & Author</h3>
                <p class="rank">⚔️ MOJO-JOJO</p>
                <p style="color: #b8b8d1; margin-top: 0.5rem;">Core player and challenge author for the MOJO-JOJO CTF team, specializing in Digital Forensics and Incident Response.</p>
            </div>
            <div class="ctf-item">
                <h3>Software Engineering Student</h3>
                <p class="rank">🎓 INSAT</p>
                <p style="color: #b8b8d1; margin-top: 0.5rem;">Pursuing a Software Engineering degree at the National Institute of Applied Science and Technology (INSAT), combining academic rigor with practical security expertise.</p>
            </div>
            <div class="ctf-item">
                <h3>Top CTF Placements</h3>
                <p class="rank">🏆 Multiple Events</p>
                <div style="color: #b8b8d1; margin-top: 0.5rem;">
                    <ul style="list-style-type: none; padding: 0;">
                        <li style="margin-bottom: 0.3rem;">🥇 <strong>Top 1</strong> — QnQSec CTF</li>
                        <li style="margin-bottom: 0.3rem;">🏅 <strong>Top 4</strong> — Securinets Qualifications</li>
                        <li style="margin-bottom: 0.3rem;">🏅 <strong>Top 5</strong> — Darkest Hour 2026</li>
                        <li style="margin-bottom: 0.3rem;">🎖️ <strong>Top 7</strong> — Securinets Finals</li>
                        <li>⭐ <strong>Achievements</strong> — Tio CTF</li>
                    </ul>
                </div>
            </div>
            <div class="ctf-item">
                <h3>TryHackMe</h3>
                <p class="rank">⭐ Top 1% Globally</p>
                <p style="color: #b8b8d1; margin-top: 0.5rem;">Ranked in the top 1% of TryHackMe users worldwide, completing advanced rooms in DFIR, malware analysis, threat hunting, and SOC operations.</p>
            </div>
        </div>
    </section>

    <section id="writeups">
        <h2>CTF Writeups</h2>
        <div class="writeups-grid">
            <% latestWriteups.forEach(function(post) { %>
            <div class="writeup-card">
                <div class="writeup-header">
                    <h3><%= post.title %></h3>
                    <span class="writeup-category"><%= post.category %></span>
                </div>
                <p class="writeup-description"><%= post.description %></p>
                <div class="writeup-tags">
                    <% (post.tags || []).forEach(function(tag) { %>
                    <span class="tag"><%= tag %></span>
                    <% }); %>
                </div>
                <div class="writeup-footer">
                    <span style="color: #b8b8d1; font-size: 0.9rem;"><%= post.stats %></span>
                    <a href="/writeups/<%= post.slug %>" class="cta-button" style="padding: 0.5rem 1rem; font-size: 0.9rem;">Read Writeup</a>
                </div>
            </div>
            <% }); %>
        </div>
        <div style="text-align:center; margin-top:2rem;">
            <a href="/writeups" class="cta-button">View All Writeups</a>
        </div>
    </section>

    <section id="projects">
        <h2>Personal Projects</h2>
        <div class="projects-grid">
            <% if (projects.length === 0) { %>
            <div class="project-card">
                <h3>Coming Soon</h3>
                <p>Currently working on exciting DFIR and Blue Team projects. Check back soon for updates on my latest security research and tools.</p>
                <div class="project-tags">
                    <span class="tag">DFIR</span>
                    <span class="tag">Malware Analysis</span>
                    <span class="tag">Threat Intel</span>
                </div>
            </div>
            <% } else { %>
            <% projects.forEach(function(project) { %>
            <div class="project-card">
                <h3><%= project.title %></h3>
                <p><%= project.description %></p>
                <div class="project-tags">
                    <% (project.tags || []).forEach(function(tag) { %>
                    <span class="tag"><%= tag %></span>
                    <% }); %>
                </div>
            </div>
            <% }); %>
            <% } %>
        </div>
    </section>

    <section id="certs">
        <h2>Certifications</h2>
        <div class="cert-grid">
            <div class="cert-card">
                <div class="cert-icon">🛡️</div>
                <h3>Google Cybersecurity Professional Certificate</h3>
                <p style="color: #b8b8d1;">Google</p>
                <p style="color: #00ff9d; font-size: 0.9rem; margin-top: 0.5rem;">2024</p>
            </div>
            <div class="cert-card">
                <div class="cert-icon">🔐</div>
                <h3>TryHackMe SOC Level 1</h3>
                <p style="color: #b8b8d1;">TryHackMe</p>
                <p style="color: #00ff9d; font-size: 0.9rem; margin-top: 0.5rem;">Certified</p>
            </div>
            <div class="cert-card">
                <div class="cert-icon">⚡</div>
                <h3>Top 1% on TryHackMe</h3>
                <p style="color: #b8b8d1;">TryHackMe Platform</p>
                <p style="color: #00ff9d; font-size: 0.9rem; margin-top: 0.5rem;">Global Ranking</p>
            </div>
        </div>
    </section>

    <section id="contact">
        <h2>Get In Touch</h2>
        <div class="contact-content">
            <p style="font-size: 1.1rem; color: #b8b8d1; margin-bottom: 2rem;">
                Interested in working together or discussing cybersecurity opportunities? 
                Feel free to reach out through any of the platforms below.
            </p>
            <div class="contact-links">
                <a href="mailto:azizhaddadi10@gmail.com" class="contact-link">Email</a>
                <a href="https://www.linkedin.com/in/aziz-haddadi-825209288" target="_blank" class="contact-link">LinkedIn</a>
                <a href="https://github.com/aziz-haddadi" target="_blank" class="contact-link">GitHub</a>
            </div>
        </div>
    </section>

    <button class="back-to-top" id="backToTop" aria-label="Back to top">↑</button>

<%- include('partials/footer') %>
